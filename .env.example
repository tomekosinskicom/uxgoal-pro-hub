# Supabase — anon/publishable keys are public by design (safe to ship to client)
# Get these from Supabase project settings → API
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""

# Same values, exposed to the client by Vite (must be VITE_-prefixed)
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

# NEVER put SUPABASE_SERVICE_ROLE_KEY here or in any committed file.
# That key bypasses RLS. Keep it only in deploy-time env (Cloudflare secret).
